# =============================================================================
# Copy this file to `.env` and fill in real values for the machine it runs on
# (your laptop or the production server). `.env` is gitignored — never commit
# real secrets. Next.js loads `.env` automatically in every mode (dev, build,
# start), and `scripts/load-env.ts` loads it for tools that run outside Next
# (drizzle-kit, and the seed/worker/admin-create/test-mail scripts) — so this
# single file is all you need on any given machine.
# =============================================================================

# --- App / public -------------------------------------------------------------
# Canonical URL of this app (metadata/OG tags + referral invite links).
NEXT_PUBLIC_SITE_URL=https://octanlink.com

# Port the server listens on (`pnpm dev` / `pnpm start`). Leave unset to
# default to 3000.
PORT=3200

# Game-provider API. Only hit by `pnpm fetch:providers` / the providers.sync
# job to (re)load game_providers; the app itself reads providers from the DB.
PROVIDER_API_BASE_URL=https://digitlink.mobi/prod-api/member/game/available-providers

# --- Database (Drizzle + pg-boss share this Postgres) --------------------------
DATABASE_URL=postgres://user:password@localhost:5432/dbname

# --- Admins ---------------------------------------------------------------------
# Admins are DATA, not env. The seed creates a few (super_admin/admin/finance/
# support), password "admin1234". Create more any time — no env, no restart:
#   pnpm admin:create -- --email a@b.com --username alice --password pw --role super_admin

# --- Cloudflare R2 (image storage — lib/storage/r2.ts) ---------------------------
# S3-compatible. Leave the credential blanks empty to run without uploads.
# Endpoint is derived from R2_ACCOUNT_ID (https://<account_id>.r2.cloudflarestorage.com).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=octanlink-media
# Public bucket / CDN domain used to build public asset URLs.
R2_PUBLIC_BASE_URL=https://media.octanlink.com

# --- SMTP email (lib/mail, delivered via the `email.send` pg-boss job) ----------
# Transactional email: admin invites, support-ticket replies, email
# verification, admin alerts. Leave SMTP_HOST blank to use the built-in
# console fallback (emails are logged, not sent) — see lib/mail/transport.ts.
SMTP_HOST=
SMTP_PORT=587
# true only for implicit TLS on port 465; 587 uses STARTTLS (secure=false).
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Envelope From, e.g. "OctanLink <no-reply@octanlink.com>".
MAIL_FROM=OctanLink <no-reply@octanlink.com>
# Where admin/alert emails go when a flow has no specific recipient.
MAIL_ADMIN=admin@octanlink.com
