# Copy this file to .env.local to override any value below for your machine.
# .env.development / .env.production already hold sane defaults for each mode
# and are committed to the repo — you normally don't need a .env.local at all.

# Base URL of the game-provider API. Only read once, the first time
# data/providers.sc.json / providers.gc.json don't exist yet (see
# lib/providers.ts) — after that the app serves the cached JSON and never
# calls this URL again. Also used by `npm run fetch:providers` to refresh
# the cached snapshot on demand.
PROVIDER_API_BASE_URL=https://digitlink.mobi/prod-api/member/game/available-providers

# Canonical URL of this app itself (used for metadata/OG tags). Point this
# at your real deployment domain in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# PostgreSQL connection string used by Drizzle (drizzle.config.ts + lib/db)
# and pg-boss (background jobs share the same database).
# .env.development ships a local default; override here (or in .env.local) for
# your own DB, and set the real credentials in the deploy environment.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/digit

# --- Admins ---
# Admins are managed as data (role-based), not via env. The seed creates
# super_admin/admin/finance/support accounts (password "admin1234"); add more
# with `pnpm admin:create -- --email .. --username .. --password .. --role ..`.

# --- Cloudflare R2 (image storage, lib/storage/r2.ts) ---
# S3-compatible. Endpoint is https://<account_id>.r2.cloudflarestorage.com.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=octanlink-media
# Public bucket / CDN domain used to build public asset URLs.
R2_PUBLIC_BASE_URL=https://media.octanlink.com

# --- SMTP email (lib/mail, delivered via the `email.send` pg-boss job) ---
# Transactional email: admin invites, support-ticket replies, email
# verification, admin alerts. Leave SMTP_HOST blank in dev to use the built-in
# console fallback (emails are logged, not sent) — see lib/mail/transport.ts.
SMTP_HOST=
SMTP_PORT=587
# true only for implicit TLS on port 465; 587 uses STARTTLS (secure=false).
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Envelope From, e.g. "Octan Link <no-reply@octanlink.com>".
MAIL_FROM=Octan Link <no-reply@octanlink.com>
# Where admin/alert emails go when a flow has no specific recipient.
MAIL_ADMIN=admin@octanlink.com
