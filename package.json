{
  "name": "octanlink",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "dev": "node scripts/next-with-env.mjs dev",
    "build": "next build",
    "start": "node scripts/next-with-env.mjs start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify": "tsc --noEmit && next lint && prettier --check . && next build",
    "fetch:providers": "node --env-file=.env scripts/fetch-providers.mjs",
    "db:generate": "cross-env NODE_NO_WARNINGS=1 drizzle-kit generate",
    "db:migrate": "cross-env NODE_NO_WARNINGS=1 drizzle-kit migrate",
    "db:push": "cross-env NODE_NO_WARNINGS=1 drizzle-kit push",
    "db:studio": "cross-env NODE_NO_WARNINGS=1 drizzle-kit studio",
    "db:seed": "tsx scripts/seed.ts",
    "worker": "tsx scripts/worker.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "admin:create": "tsx scripts/create-admin.ts",
    "test:mail": "tsx scripts/test-mail.ts",
    "agent:seed": "tsx scripts/seed-agent.ts",
    "db:test": "tsx scripts/test-db.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1078.0",
    "@aws-sdk/s3-request-presigner": "^3.1078.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^11.11.17",
    "lucide-react": "^0.468.0",
    "next": "^14.2.18",
    "next-themes": "^0.4.4",
    "nodemailer": "^9.0.3",
    "pg-boss": "^12.24.1",
    "postgres": "^3.4.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20.17.9",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^18.3.14",
    "@types/react-dom": "^18.3.2",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.18",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "tailwindcss": "^3.4.16",
    "tsx": "^4.22.5",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  }
}
